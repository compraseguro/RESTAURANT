# Copie este archivo a `.env` y complete con sus datos reales.

# Contribuyente emisor (debe coincidir con el certificado .pfx)
SUNAT_RUC=20123456789
# Usuario secundario SOL (sin RUC delante en este campo; se concatena en código)
SUNAT_USUARIO_SOL=MODDATOS
SUNAT_CLAVE_SOL=moddatos
# beta | produccion
SUNAT_AMBIENTE=beta

# Certificado digital emitido por entidad acreditada (SUNAT / ICP Peru)
CERT_PFX_PATH=./certs/emisor.pfx
CERT_PFX_PASSWORD=cambiar

# Carpeta base: se crean subcarpetas xml/, signed/, cdr/, pdf/
OUTPUT_DIR=./output

# --- API HTTP (integración con el backend Node; python api_server.py) ---
# Mismo valor que "Secreto HTTP" en el panel Facturación electrónica (opcional en desarrollo).
# EFACT_HTTP_SECRET=
# EFACT_HTTP_HOST=127.0.0.1
# EFACT_HTTP_PORT=8765
