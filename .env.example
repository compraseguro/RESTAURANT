# === PRODUCCIÓN (Render, Railway, etc.) ===
# Los datos NO se borran por "actualizar el código". Se pierden si el SQLite vive
# en el disco del contenedor (EFÍMERO): cada deploy = carpeta nueva = restaurant.db vacío.
# OBLIGATORIO: volumen persistente + DB_PATH absoluto en ese volumen.
#   Render: Disk montado en /data → DB_PATH=/data/restaurant.db
# Ver DEPLOY_GITHUB_VERCEL_RENDER.md sección 1b. En logs del servidor busca [CRÍTICO] si falta.

PORT=3001
JWT_SECRET=change_this_to_a_long_random_secret

# --- Sincronización SaaS hacia https://restofadey.pe (cada web service cliente) ---
# NEXT_PUBLIC_API_URL= URL pública de ESTE web service (para enlaces de vouchers)
NEXT_PUBLIC_API_URL=
# URL de la plataforma administrativa central (alias: CENTRAL_PLATFORM_URL)
NEXT_PUBLIC_PLATFORM_URL=https://restofadey.pe
CENTRAL_PLATFORM_URL=https://restofadey.pe
API_SECRET_KEY=
CLIENT_ID=
# Intervalo de consulta GET /api/payments/status (ms, mín. 15000)
# PLATFORM_PAYMENT_POLL_MS=60000
RESTAURANT_ID=
WEBSERVICE_ID=
LICENSE_KEY=
# Alias opcional de URL pública del API
# PUBLIC_API_BASE_URL=

# Local: ./restaurant.db  |  Render con Disk: /data/restaurant.db
DB_PATH=./restaurant.db
# Opcional. Por defecto las subidas van a la carpeta uploads junto al .db (p. ej. /data/uploads si DB_PATH=/data/restaurant.db).
# UPLOADS_DIR=/data/uploads

# Administrador maestro (login /master). En producción conviene definir valores propios aquí o en el panel del host.
MASTER_USERNAME=Romero25879
MASTER_PASSWORD=2587903042007

# Comma-separated allowlist. Leave empty only for local development.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional
# DEBUG_ORDERS=1  # logs detallados POST/PUT pedidos en consola del servidor
NODE_ENV=production

# Consulta DNI/RUC en caja (botón «Padrón»). API key: https://decolecta.com/profile — también en Render/Docker como env.
# Alias: DECOLECTA_API_KEY. Reinicie Node tras cambiar.
# PERU_CONSULTAS_TOKEN=

# --- Bot e-fact (Python en server/efact, mismo host que Node, o Docker) ---
# OBLIGATORIO para producción: URL base del bot y secreto compartido (header X-EFACT-SECRET). No se editan en el panel web.
# Si están definidas aquí, tienen prioridad sobre cualquier URL/token guardado en la base del restaurante.
# Docker Compose suele definir EFACT_API_URL en el servicio app; en local puedes descomentar:
# EFACT_API_URL=http://127.0.0.1:8765
# EFACT_HTTP_SECRET=un_secreto_largo_que_coincida_con_el_.env_del_bot

# Notificación al cerrar caja por correo
# 1 = habilitado, 0 = deshabilitado
CASH_CLOSE_NOTIFY_ENABLED=1
# Destinatario: email del usuario Administrador en Configuración → Usuarios (el más reciente actualizado).
# Respaldo: CASH_CLOSE_EMAIL, luego email de «Mi restaurante».
CASH_CLOSE_EMAIL=
#
# IMPORTANTE: Formspree (por defecto) envía al correo del formulario en formspree.io, NO al del administrador.
# Para que llegue a restofadey@gmail.com (u otro admin), configure SMTP (recomendado con Gmail):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=restofadey@gmail.com
# SMTP_PASS=contraseña_de_aplicación_de_16_caracteres
# SMTP_FROM=Resto Fadey <restofadey@gmail.com>
#
# Alternativa: Resend (https://resend.com) — RESEND_API_KEY=re_xxx  RESEND_FROM=Resto Fadey <onboarding@resend.dev>
#
# Solo si no hay SMTP ni Resend:
# CASH_CLOSE_FORM_URL=https://formspree.io/f/mlgpdblo

# --- Envío de PDF del comprobante por WhatsApp (puente en tu laptop; ver whatsapp-bridge/README.md) ---
# URL del puente (local: http://127.0.0.1:9876  |  desde Render: https://TU-NGROK.ngrok-free.app)
# WHATSAPP_BRIDGE_URL=
# Mismo secreto que en whatsapp-bridge/.env
# WHATSAPP_BRIDGE_SECRET=
# URL pública del API sin /api (para armar https://.../uploads/... del PDF)
# PUBLIC_API_BASE_URL=https://tu-api.onrender.com
