# === PRODUCCIÓN (Render, Railway, etc.) ===
# Los datos NO se borran por "actualizar el código". Se pierden si el SQLite vive
# en el disco del contenedor (EFÍMERO): cada deploy = carpeta nueva = restaurant.db vacío.
# OBLIGATORIO: volumen persistente + DB_PATH absoluto en ese volumen.
#   Render: Disk montado en /data → DB_PATH=/data/restaurant.db
# Ver DEPLOY_GITHUB_VERCEL_RENDER.md sección 1b. En logs del servidor busca [CRÍTICO] si falta.

PORT=3001
JWT_SECRET=change_this_to_a_long_random_secret

# Local: ./restaurant.db  |  Render con Disk: /data/restaurant.db
DB_PATH=./restaurant.db

# Administrador maestro (login /master). En producción conviene definir valores propios aquí o en el panel del host.
MASTER_USERNAME=Romero25879
MASTER_PASSWORD=2587903042007

# Comma-separated allowlist. Leave empty only for local development.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional
NODE_ENV=production

# Notificación opcional al cerrar caja (Formspree/webhook)
# 1 = habilitado, 0 = deshabilitado
CASH_CLOSE_NOTIFY_ENABLED=1
# Endpoint de Formspree configurado
CASH_CLOSE_FORM_URL=https://formspree.io/f/mlgpdblo
# Email destino (opcional, recomendado)
CASH_CLOSE_EMAIL=
