PORT=3001
JWT_SECRET=change_this_to_a_long_random_secret

# SQLite: en Render/Railway monte un disco persistente y apunte aquí (si no, cada deploy crea BD vacía).
# Ejemplo Render: DB_PATH=/data/restaurant.db
DB_PATH=./restaurant.db

# Primer acceso administrador maestro (cambie en producción). Luego puede cambiar credenciales en panel /master.
MASTER_USERNAME=maestro
MASTER_PASSWORD=CambiarMaestro1!

# Comma-separated allowlist. Leave empty only for local development.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional
NODE_ENV=production

# Notificación opcional al cerrar caja (Formspree/webhook)
# 1 = habilitado, 0 = deshabilitado
CASH_CLOSE_NOTIFY_ENABLED=1
# Endpoint de Formspree configurado
CASH_CLOSE_FORM_URL=https://formspree.io/f/mlgpdblo
# Email destino (opcional, recomendado)
CASH_CLOSE_EMAIL=
