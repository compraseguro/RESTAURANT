{
  "name": "restaurant-platform",
  "version": "1.0.0",
  "description": "Plataforma completa para restaurante - Admin, Cocina, POS, Cliente, Delivery",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install",
    "build": "cd client && npm install --include=dev && npm run build",
    "start": "node server/index.js",
    "start:render": "bash scripts/render-start.sh",
    "efact-api": "python server/efact/api_server.py",
    "smoke": "node scripts/smoke-test.js",
    "verify:roles": "node scripts/verify-roles.js",
    "preflight": "npm run lint && npm run smoke && npm run verify:roles && npm run build",
    "test": "npm run smoke",
    "lint": "node scripts/lint-check.js",
    "reset-demo": "node scripts/reset-demo.js",
    "prepare:first-owner": "node scripts/prepare-first-owner.js",
    "serve:offer": "npx --yes serve rolando-offer -l 8080"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.2",
    "socket.io": "^4.8.1",
    "sql.js": "^1.11.0",
    "uuid": "^11.0.3"
  },
  "optionalDependencies": {
    "printer": "^0.4.0"
  }
}
