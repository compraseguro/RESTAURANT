{
  "name": "restaurant-platform",
  "version": "1.0.0",
  "description": "Plataforma completa para restaurante - Admin, Cocina, POS, Cliente, Delivery",
  "main": "electron/main.js",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install",
    "build": "cd client && npm install --include=dev && npm run build",
    "start": "node server/index.js",
    "printing-bridge": "node server/index.js",
    "start:render": "bash scripts/render-start.sh",
    "efact-api": "python server/efact/api_server.py",
    "smoke": "node scripts/smoke-test.js",
    "verify:roles": "node scripts/verify-roles.js",
    "preflight": "npm run lint && npm run smoke && npm run verify:roles && npm run build",
    "test": "npm run smoke",
    "lint": "node scripts/lint-check.js",
    "reset-demo": "node scripts/reset-demo.js",
    "prepare:first-owner": "node scripts/prepare-first-owner.js",
    "serve:offer": "npx --yes serve rolando-offer -l 8080",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run server\" \"cd client && npm run dev\" \"cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis",
    "electron:dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.2",
    "socket.io": "^4.8.1",
    "sql.js": "^1.11.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^37.10.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.restofadey.desktop",
    "productName": "Resto FADEY",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "output": "release/dist",
      "buildResources": "client/public"
    },
    "files": [
      "electron/**",
      "client/dist/**",
      "server/printing/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "RestoFADEY Setup.exe",
      "icon": "client/public/icon-512.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Resto FADEY"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.restofadey.com/desktop"
      }
    ]
  }
}
