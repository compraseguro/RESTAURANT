# Copie a .env y ajuste. Solo afecta al build / dev del cliente.

# URL del backend (opcional; si no existe, en prod se usa el valor por defecto del código)
# VITE_API_URL=http://localhost:3001

# Asistente de impresión (Electron) en la PC del cliente: escaneo automático al iniciar sesión.
# Por defecto: hosts 127.0.0.1 y localhost, puertos 3001–3025. Opcional:
# VITE_PRINTING_ASSISTANT_PORT_COUNT=30
# VITE_PRINTING_ASSISTANT_PORTS=3001,3002,3010
# VITE_PRINTING_ASSISTANT_HOSTS=127.0.0.1
