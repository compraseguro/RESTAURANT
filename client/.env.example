# Copie a .env y ajuste. Solo afecta al proxy de desarrollo (npm run dev).
# Si la API usa el puerto 3001, ejecute el print-agent en otro puerto, p. ej. PORT=3002
# y descomente la línea siguiente:
# VITE_PRINT_AGENT_TARGET=http://127.0.0.1:3002

# URL del backend (opcional; si no existe, en prod se usa el valor por defecto del código)
# VITE_API_URL=http://localhost:3001
