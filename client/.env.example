# Copie a .env y ajuste. Solo afecta al build / dev del cliente.
# URL base del microservicio local de impresión (ESC/POS por IP). Por defecto el código usa http://127.0.0.1:3049
# VITE_PRINT_SERVICE_URL=http://127.0.0.1:3049

# Proxy de Vite (npm run dev): destino del prefijo /local-print-service (opcional)
# VITE_PRINT_SERVICE_DEV_PROXY=http://127.0.0.1:3049

# Enlace visible en el panel de impresora: instalador o ZIP del microservicio Windows (hosting propio, S3, GitHub Releases…)
# VITE_PRINT_INSTALLER_URL=https://su-dominio.com/descargas/RestoFadey-Print-Setup.exe

# URL del backend (opcional; si no existe, en prod se usa el valor por defecto del código)
# VITE_API_URL=http://localhost:3001
