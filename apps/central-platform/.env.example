PORT=4000
NODE_ENV=development

# Base de datos central (aislada de cada restaurante)
DATABASE_URL=./central.db

JWT_SECRET=central_jwt_change_in_production
API_SECRET_KEY=shared_secret_between_pos_and_central

# Supabase (opcional — métricas o storage de vouchers)
SUPABASE_SERVICE_ROLE_KEY=

# URL del POS de referencia / landing
NEXT_PUBLIC_POS_URL=https://pos.restofadey.pe

CORS_ORIGIN=http://localhost:4000,https://restofadey.pe
