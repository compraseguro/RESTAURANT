# Secreto compartido con el servidor API (misma variable WHATSAPP_BRIDGE_SECRET en Render/.env del Node)
WHATSAPP_BRIDGE_SECRET=cambiar_por_una_cadena_larga

# Puerto y enlace (127.0.0.1 = solo tu PC; use 0.0.0.0 + ngrok si Render debe llamar desde internet)
WHATSAPP_BRIDGE_PORT=9876
WHATSAPP_BRIDGE_BIND=127.0.0.1
